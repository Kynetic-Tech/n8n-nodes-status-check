{
  "name": "@status-check/n8n-nodes-status-check",
  "version": "1.2.0",
  "description": "n8n community node for Status Check - Domain and email validation for workflow automation",
  "keywords": [
    "n8n-community-node-package",
    "n8n-node",
    "status-check",
    "email-validation",
    "domain-validation",
    "lead-validation",
    "workflow-automation"
  ],
  "license": "MIT",
  "homepage": "https://docs.status-check.io",
  "author": {
    "name": "Status Check",
    "email": "support@status-check.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kynetic-Tech/n8n-nodes-status-check.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build",
    "release": "npm version patch && git push && git push --tags"
  },
  "files": [
    "dist/credentials",
    "dist/nodes",
    "LICENSE",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/StatusCheckApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/StatusCheck/StatusCheck.node.js",
      "dist/nodes/CreditsDepletedTrigger/StatusCheckCreditsDepletedTrigger.node.js",
      "dist/nodes/CreditsLowTrigger/StatusCheckCreditsLowTrigger.node.js",
      "dist/nodes/LeadCreatedTrigger/StatusCheckLeadCreatedTrigger.node.js",
      "dist/nodes/LeadUpdatedTrigger/StatusCheckLeadUpdatedTrigger.node.js",
      "dist/nodes/LeadValidatedTrigger/StatusCheckLeadValidatedTrigger.node.js",
      "dist/nodes/ValidationCompleteTrigger/StatusCheckValidationCompleteTrigger.node.js",
      "dist/nodes/ValidationFailedTrigger/StatusCheckValidationFailedTrigger.node.js",
      "dist/nodes/ValidationStartedTrigger/StatusCheckValidationStartedTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "eslint-plugin-n8n-nodes-base": "^1.12.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "prettier": "^2.8.8",
    "typescript": "^5.0.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {}
}
